# ============================================================
# Backend Environment Variables (artifacts/api-server)
# ============================================================
# For local dev: copy to artifacts/api-server/.env
# For Render:   add these in Render Dashboard → Service → Environment

# --- Database (Neon PostgreSQL) ---
# Get from: https://neon.tech → New Project → Connection String (pooled)
DATABASE_URL=postgresql://user:password@host.neon.tech/fracas_rams?sslmode=require

# --- Server ---
PORT=10000

# --- CORS ---
# Comma-separated list of allowed frontend origins
# Example: https://fracas-rams.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- Gemini AI ---
# Get from: https://aistudio.google.com/apikey
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_api_key_here
