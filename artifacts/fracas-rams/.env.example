# ============================================================
# Frontend Environment Variables (artifacts/fracas-rams)
# ============================================================
# For local dev: copy to artifacts/fracas-rams/.env
# For Vercel:   add these in Vercel Dashboard → Project → Settings → Environment Variables

# --- Backend API URL ---
# Point to your Render (or local) API server.
# Leave empty to use relative /api/* routing (same host, Vercel rewrites).
# Example: https://fracas-rams-api.onrender.com
VITE_API_URL=

# --- Vite dev server settings (local only, not needed for Vercel) ---
PORT=3000
BASE_PATH=/
