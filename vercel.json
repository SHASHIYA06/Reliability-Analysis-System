{
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @workspace/fracas-rams run build",
  "outputDirectory": "artifacts/fracas-rams/dist/public",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "BASE_PATH": "/"
  }
}