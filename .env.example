# ============================================================
# BEML FRACAS & RAMS System — Root Environment Template
# ============================================================
# Copy this file to .env and fill in your values.

# --- Database (Neon PostgreSQL recommended) ---
# Get from: https://neon.tech  →  New Project → Connection String
DATABASE_URL=postgresql://user:password@host.neon.tech/fracas_rams?sslmode=require

# --- API Server ---
PORT=8080

# --- CORS (comma-separated list of frontend URLs) ---
# Example: https://fracas-rams.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# --- Gemini AI (for root-cause analysis) ---
# Get from: https://aistudio.google.com/apikey
AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
AI_INTEGRATIONS_GEMINI_API_KEY=your_gemini_api_key_here
